APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# Cloudflare R2 — bucket for Content Planner social media (photos + videos
# scheduled to FB/IG). Separate from the website's R2 (flare-web). Egress is
# free, which is why we use R2 over S3: every Meta-side download of a Reel
# costs us nothing. See docs/cloudflare-r2-setup.md for how to provision the
# bucket, create API tokens, and wire up the custom domain.
#
# R2_ACCESS_KEY_ID    — From Cloudflare dashboard > R2 > Manage R2 API Tokens.
# R2_SECRET_ACCESS_KEY — Pair of the above; shown once at token creation.
# R2_BUCKET           — Bucket name (default: flare-social).
# R2_ENDPOINT         — https://<account-id>.r2.cloudflarestorage.com — the
#                       S3-API endpoint. Account id from R2 dashboard URL.
# R2_PUBLIC_URL       — Public CDN base, e.g. https://media-flare.zeroabsolute.com.
#                       Meta servers fetch media from here, so it must resolve
#                       publicly. Configure as a custom domain on the bucket.
# CONTENT_PLANNER_MEDIA_DISK — Set to 'r2_social' once the above are populated;
#                       leave 'public' to keep using local storage during dev.
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=flare-social
R2_ENDPOINT=
R2_PUBLIC_URL=
CONTENT_PLANNER_MEDIA_DISK=public

# Meta token fallback: when meta_tokens (OAuth) is empty, MetaTokenResolver
# reads hrms_meta_credentials on the DIS database. Set to HRMS's APP_KEY so
# the access_token (Crypt::encryptString'd by HRMS) can be decrypted.
HRMS_APP_KEY=

# Canva Connect API — Visual Studio "Open in Canva" flow.
# Register the app at https://www.canva.com/developers/ and add a redirect URI
# matching CANVA_REDIRECT_URI below (resolved against APP_URL). For local dev,
# point APP_URL at an HTTPS tunnel (ngrok / cloudflare tunnel) — Canva rejects
# http://localhost callbacks.
CANVA_CLIENT_ID=
CANVA_CLIENT_SECRET=
CANVA_REDIRECT_URI=/marketing/canva/callback
CANVA_FEATURE_CONNECT=false

# Meta Instagram DM Webhook — receives every IG DM in real-time so the
# dashboard matches Meta Business Suite exactly. The receiver lives at
# /webhooks/meta/instagram in this app.
# 1. Generate verify token: openssl rand -hex 16 (paste same value in Meta
#    App Dashboard > Webhooks > Verify Token).
# 2. META_APP_SECRET is the Meta App secret from developers.facebook.com
#    (App Settings > Basic > App Secret).
# 3. Set META_IG_WEBHOOK_START_DATE after test DM succeeds (YYYY-MM-DD of
#    the day webhook went live). Dates before use the API sample fallback.
# 4. META_IG_CONVERSATION_GAP_MINUTES: a new DM starts a new conversation
#    if no prior incoming from same thread within this window. 1440 = 24h.
META_APP_SECRET=
META_WEBHOOK_VERIFY_TOKEN=
META_IG_WEBHOOK_START_DATE=
META_IG_CONVERSATION_GAP_MINUTES=1440

VITE_APP_NAME="${APP_NAME}"

# DIS integration — Flare reads inventory data directly from the DIS database
# through the `dis` connection, but all WRITES to influencer products,
# merch-calendar, etc. route through the DIS internal HTTP API so that
# business logic (stock movements, Zoho sync, audit trail) stays in DIS.
#
# DIS_API_URL           — Base URL of the DIS app that hosts /api/internal/*
#                         routes (production: https://dis.zeroabsolute.dev).
# DIS_INTERNAL_API_KEY  — Shared secret. MUST match DIS .env value. Verified
#                         by VerifyInternalApiKey middleware on every call.
#                         Generate with: openssl rand -hex 32
# DIS_APP_URL           — Browser-facing URL of DIS, used only for cross-app
#                         links (e.g. "open transfer order in DIS").
DIS_API_URL=http://localhost:8000
DIS_INTERNAL_API_KEY=
DIS_APP_URL=http://localhost:8000
